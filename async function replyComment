<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Moderator Panel</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
*{box-sizing:border-box}
body{margin:0;font-family:Arial;background:linear-gradient(135deg,#ffe1ef,#ffc1dc);color:#222}
.top{background:white;padding:12px;border-bottom:2px solid #ff5bad;font-weight:900}
.box{width:94%;max-width:820px;margin:22px auto;background:white;border-radius:24px;padding:22px;box-shadow:0 15px 35px #ff3f9d33}
input{width:100%;padding:13px;margin:8px 0;border:1px solid #ffc2dc;border-radius:14px}
button{border:0;border-radius:999px;background:#ff3f9d;color:white;padding:11px 15px;font-weight:900;margin:6px 0}
.hidden{display:none!important}
.comment{background:#fff6fb;border-left:5px solid #ff3f9d;border-radius:14px;padding:12px;margin:10px 0}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:white;color:#ff3f9d;padding:12px 18px;border-radius:999px;box-shadow:0 10px 25px #0003;display:none;font-weight:900;z-index:99}

.kickToast{
  position:fixed;
  left:50%;
  bottom:26px;
  transform:translateX(-50%) translateY(20px);
  background:white;
  color:#ff3f9d;
  padding:13px 18px;
  border-radius:999px;
  box-shadow:0 12px 30px #0004;
  font-weight:900;
  opacity:0;
  pointer-events:none;
  transition:.25s;
  z-index:9999;
}
.kickToast.show{
  opacity:1;
  transform:translateX(-50%) translateY(0);
}
</style>
</head>
<body>
<div class="top">🛡 Moderator Panel</div>

<section class="box" id="loginBox">
<h2>Login Moderator</h2>
<input id="name" placeholder="Nama moderator">
<input id="key" placeholder="Key 1 / Key 2">
<button onclick="login()">Masuk</button>
</section>

<section class="box hidden" id="panel">
<h2>Komentar User</h2>
<div id="comments">Memuat...</div>
<button onclick="logout()">Logout</button>
</section>

<div id="toast" class="toast"></div>


<script>
function kickToast(msg){
  const t=document.getElementById("kickToast");
  if(!t) return;
  t.innerText=msg;
  t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"),1800);
}

function show(msg){
  toast.innerText=msg;
  toast.style.display="block";
  setTimeout(()=>toast.style.display="none",1800);
}

async function login(){
  const n=document.getElementById("name").value.trim();
  const k=document.getElementById("key").value.trim();

  if(!n||!k) return show("Isi nama dan key");

  const r=await fetch("/api/admin-login-real",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({name:n,key:k})
  });

  const d=await r.json().catch(()=>({}));

  if(!r.ok) return show(d.message||"Login gagal");

  if(d.role!=="moderator" && d.role!=="admin" && d.role!=="owner"){
    return show("Akun ini bukan moderator");
  }

  sessionStorage.setItem("mod_login",d.name);
  sessionStorage.setItem("mod_role",d.role);

  loginBox.classList.add("hidden");
  panel.classList.remove("hidden");
  loadComments();
}

function logout(){
  sessionStorage.removeItem("mod_login");
  sessionStorage.removeItem("mod_role");
  location.reload();
}

async function loadComments(){
  const r=await fetch("/api/posts?t="+Date.now());
  const posts=await r.json().catch(()=>[]);

  let html="";
  posts.forEach(p=>{
    (p.comments||[]).forEach((c,i)=>{
      html+=`
      <div class="comment">
        <b>${c.name||"Anonim"}</b><br>
        <small>${p.title||"Video"}</small>
        <p>${c.text||c.comment||""}</p>
        <button onclick="deleteComment('${p.id}',${i})">Hapus Komentar</button>
      
${c.reply ? `
<div style="background:#ffe8f4;padding:8px;border-radius:10px;margin-top:6px">
<b>${c.reply.name||"Admin"}</b>
<p>${c.reply.text||""}</p>
</div>` : ""}

<input id="reply_${p.id}_${i}" placeholder="Balas komentar...">
<button onclick="replyComment('${p.id}',${i})">Reply</button>
</div>`;

    });
  });

  comments.innerHTML=html || "Belum ada komentar";
}



async function replyComment(postId,index){
  const inp=document.getElementById("reply_"+postId+"_"+index);
  const reply=inp ? inp.value.trim() : "";

  if(!reply) return show("Isi reply dulu");

  const r = await fetch("/api/admin/posts/"+postId+"/comments/"+index+"/reply",{
  method:"POST",
  headers:{
    "Content-Type":"application/json",
    "x-admin-name": sessionStorage.getItem("mod_login") || "Moderator"
  },
  body: JSON.stringify({
    text: reply,
    adminName: sessionStorage.getItem("mod_login") || "Moderator",
    role: "moderator"
  })
});

  const d=await r.json().catch(()=>({}));

  if(!r.ok){
    return show(d.message || "Gagal reply");
  }

  show("Reply terkirim");
  inp.value="";
  loadComments();
}


async function deleteComment(postId,index){
  const r=await fetch("/api/admin/comment/"+postId+"/"+index,{
    method:"DELETE",
    headers:{"x-admin-name":sessionStorage.getItem("mod_login")||""}
  });

  if(!r.ok) return show("Gagal hapus komentar");
  show("Komentar dihapus");
  loadComments();
}

let modTyping=false;

document.addEventListener("focusin",e=>{
  if(e.target.matches("input,textarea")) modTyping=true;
});

document.addEventListener("focusout",e=>{
  if(e.target.matches("input,textarea")){
    setTimeout(()=>modTyping=false,700);
  }
});

setInterval(()=>{
  if(!panel.classList.contains("hidden") && !modTyping) loadComments();
},3000);
</script>


<script id="MOD_STATUS_GUARD">
setInterval(async()=>{
  const name=sessionStorage.getItem("mod_login");
  if(!name) return;

  const r=await fetch("/api/check-account-status/"+encodeURIComponent(name)+"?t="+Date.now());
  const d=await r.json().catch(()=>({}));

  if(!r.ok || d.status!=="active"){
    sessionStorage.removeItem("mod_login");
    sessionStorage.removeItem("mod_role");
    kickToast("Akun kamu sudah tidak aktif / dikick owner");
    location.href="/mod.html";
  }
},2000);
</script>

<div id="kickToast" class="kickToast"></div>
</body>
</html>
